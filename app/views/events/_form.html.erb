<%= form_with(model: event) do |form| %>
  <% if event.errors.any? %>
    <div class="alert alert-danger">
      <h2 class="h5 text-danger"><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h2>

      <ul class="mb-0">
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control form-control-lg" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-control form-control-lg", rows: 4 %>
  </div>

  <div class="mb-3">
    <%= form.label :event_date, class: "form-label" %>
    <%= form.date_field :event_date, class: "form-control form-control-lg" %>
  </div>

  <div class="mb-3">
    <%= form.label :time_limit_per_lt, class: "form-label" %>
    <%= form.number_field :time_limit_per_lt, class: "form-control form-control-lg" %>
  </div>

  <div class="mb-3">
    <%= form.label :hashtag, class: "form-label" %>
    <div class="input-group input-group-lg">
      <span class="input-group-text">#</span>
      <%= form.text_field :hashtag, class: "form-control", placeholder: "ruby kaigi" %>
    </div>
    <div class="form-text text-muted">
      <%= t("events.form.hashtag_help", default: "SNS share hashtag (without #)") %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary btn-lg" %>
    <%= link_to t("events.form.cancel"), events_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>
