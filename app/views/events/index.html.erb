<% if notice.present? %>
  <p class="alert alert-success"><%= notice %></p>
<% end %>
<% content_for :title, t("events.index.title") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= t("events.index.title") %></h1>
  <%= link_to t("events.index.new_event"), new_event_path, class: "btn btn-primary" %>
</div>

<div id="events">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th><%= Event.human_attribute_name(:title) %></th>
        <th><%= Event.human_attribute_name(:event_date) %></th>
        <th><%= t("events.index.actions", default: "Actions") %></th>
      </tr>
    </thead>
    <tbody>
      <% @events.each do |event| %>
        <tr id="<%= dom_id event %>">
          <td><%= event.title %></td>
          <td><%= l(event.event_date, format: :default) rescue event.event_date.strftime("%Y-%m-%d") %></td>
          <td>
            <div class="btn-group" role="group">
              <%= link_to t("events.show.title", default: "Show"), event, class: "btn btn-sm btn-outline-primary" %>
              <%= link_to t("events.show.edit"), edit_event_path(event), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to t("events.show.destroy"), event, method: :delete, class: "btn btn-sm btn-outline-danger", form: { style: "display:inline-block;" }, data: { turbo_confirm: t("events.show.confirm_destroy") } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
