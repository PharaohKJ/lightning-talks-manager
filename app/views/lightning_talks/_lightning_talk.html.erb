<div id="<%= dom_id lightning_talk %>" class="list-group-item py-3" data-id="<%= lightning_talk.id %>" style="cursor: move;">
  <div class="d-flex w-100 justify-content-between align-items-center">
    <div>
      <h3 class="mb-1 fw-bold text-primary text-break"><%= lightning_talk.title %></h3>
      <small class="text-muted"><%= lightning_talk.speaker_name %></small>
    </div>
    <div class="text-end d-flex flex-column align-items-end gap-2">
      <span class="badge bg-secondary fs-5">
        <i class="bi bi-stopwatch me-1"></i><%= lightning_talk.duration %> <%= t("datetime.prompts.minute", default: "min") %>
      </span>
      <% share_text = "#{lightning_talk.title} - #{lightning_talk.speaker_name}" %>
      <% share_url = "https://x.com/intent/tweet?text=#{u(share_text)}&hashtags=#{u(lightning_talk.event.hashtag)}" %>
      <%= link_to share_url, class: "btn btn-sm btn-outline-dark", target: "_blank" do %>
        <i class="bi bi-twitter-x me-1"></i><%= t("events.show.share_to_x") %>
      <% end %>
    </div>
  </div>
</div>
